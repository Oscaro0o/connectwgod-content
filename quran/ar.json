[
  { "id": "fatiha1_5", "ref": "الفاتحة ١:‏٥", "themes": ["faith"], "text": "إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ." },
  { "id": "baqara2_286", "ref": "البقرة ٢:‏٢٨٦", "themes": ["strength", "hope"], "text": "لَا يُكَلِّفُ اللَّهُ نَفْسًا إِلَّا وُسْعَهَا." },
  { "id": "inshirah94_6", "ref": "الشرح ٩٤:‏٦", "themes": ["hope", "comfort"], "text": "إِنَّ مَعَ الْعُسْرِ يُسْرًا." },
  { "id": "baqara2_152", "ref": "البقرة ٢:‏١٥٢", "themes": ["gratitude", "faith"], "text": "فَاذْكُرُونِي أَذْكُرْكُمْ وَاشْكُرُوا لِي وَلَا تَكْفُرُونِ." },
  { "id": "rad13_28", "ref": "الرعد ١٣:‏٢٨", "themes": ["peace", "comfort"], "text": "أَلَا بِذِكْرِ اللَّهِ تَطْمَئِنُّ الْقُلُوبُ." },
  { "id": "talaq65_3", "ref": "الطلاق ٦٥:‏٣", "themes": ["faith", "strength"], "text": "وَمَن يَتَوَكَّلْ عَلَى اللَّهِ فَهُوَ حَسْبُهُ." },
  { "id": "zumar39_53", "ref": "الزمر ٣٩:‏٥٣", "themes": ["forgiveness", "hope"], "text": "قُلْ يَا عِبَادِيَ الَّذِينَ أَسْرَفُوا عَلَىٰ أَنفُسِهِمْ لَا تَقْنَطُوا مِن رَّحْمَةِ اللَّهِ، إِنَّ اللَّهَ يَغْفِرُ الذُّنُوبَ جَمِيعًا." },
  { "id": "baqara2_261", "ref": "البقرة ٢:‏٢٦١", "themes": ["prosperity", "gratitude"], "text": "مَّثَلُ الَّذِينَ يُنفِقُونَ أَمْوَالَهُمْ فِي سَبِيلِ اللَّهِ كَمَثَلِ حَبَّةٍ أَنبَتَتْ سَبْعَ سَنَابِلَ فِي كُلِّ سُنبُلَةٍ مِّائَةُ حَبَّةٍ." },
  { "id": "yunus10_25", "ref": "يونس ١٠:‏٢٥", "themes": ["peace"], "text": "وَاللَّهُ يَدْعُو إِلَىٰ دَارِ السَّلَامِ." },
  { "id": "rad13_24", "ref": "الرعد ١٣:‏٢٤", "themes": ["peace"], "text": "سَلَامٌ عَلَيْكُم بِمَا صَبَرْتُمْ." },
  { "id": "fath48_4", "ref": "الفتح ٤٨:‏٤", "themes": ["peace", "comfort"], "text": "هُوَ الَّذِي أَنزَلَ السَّكِينَةَ فِي قُلُوبِ الْمُؤْمِنِينَ." },
  { "id": "qasas28_77", "ref": "القصص ٢٨:‏٧٧", "themes": ["peace"], "text": "إِنَّ اللَّهَ لَا يُحِبُّ الْمُفْسِدِينَ." },
  { "id": "hijr15_46", "ref": "الحجر ١٥:‏٤٦", "themes": ["peace"], "text": "ادْخُلُوهَا بِسَلَامٍ آمِنِينَ." },
  { "id": "nisa4_128", "ref": "النساء ٤:‏١٢٨", "themes": ["peace", "forgiveness"], "text": "وَالصُّلْحُ خَيْرٌ." },
  { "id": "nur24_61", "ref": "النور ٢٤:‏٦١", "themes": ["peace"], "text": "فَإِذَا دَخَلْتُم بُيُوتًا فَسَلِّمُوا عَلَىٰ أَنفُسِكُمْ تَحِيَّةً مِّنْ عِندِ اللَّهِ مُبَارَكَةً طَيِّبَةً." },
  { "id": "hashr59_23", "ref": "الحشر ٥٩:‏٢٣", "themes": ["peace", "faith"], "text": "هُوَ اللَّهُ الَّذِي لَا إِلَٰهَ إِلَّا هُوَ الْمَلِكُ الْقُدُّوسُ السَّلَامُ." },
  { "id": "saffat37_79", "ref": "الصافات ٣٧:‏٧٩", "themes": ["peace"], "text": "سَلَامٌ عَلَىٰ نُوحٍ فِي الْعَالَمِينَ." },
  { "id": "ahzab33_44", "ref": "الأحزاب ٣٣:‏٤٤", "themes": ["peace", "hope"], "text": "تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ سَلَامٌ." },
  { "id": "maida5_54", "ref": "المائدة ٥:‏٥٤", "themes": ["love", "faith"], "text": "يُحِبُّهُمْ وَيُحِبُّونَهُ." },
  { "id": "rum30_21", "ref": "الروم ٣٠:‏٢١", "themes": ["love"], "text": "وَجَعَلَ بَيْنَكُم مَّوَدَّةً وَرَحْمَةً." },
  { "id": "baqara2_195", "ref": "البقرة ٢:‏١٩٥", "themes": ["love"], "text": "إِنَّ اللَّهَ يُحِبُّ الْمُحْسِنِينَ." },
  { "id": "baqara2_222", "ref": "البقرة ٢:‏٢٢٢", "themes": ["love", "forgiveness"], "text": "إِنَّ اللَّهَ يُحِبُّ التَّوَّابِينَ وَيُحِبُّ الْمُتَطَهِّرِينَ." },
  { "id": "imran3_146", "ref": "آل عمران ٣:‏١٤٦", "themes": ["love", "strength"], "text": "وَاللَّهُ يُحِبُّ الصَّابِرِينَ." },
  { "id": "imran3_31", "ref": "آل عمران ٣:‏٣١", "themes": ["love", "faith"], "text": "قُلْ إِن كُنتُمْ تُحِبُّونَ اللَّهَ فَاتَّبِعُونِي يُحْبِبْكُمُ اللَّهُ وَيَغْفِرْ لَكُمْ ذُنُوبَكُمْ." },
  { "id": "hujurat49_9", "ref": "الحجرات ٤٩:‏٩", "themes": ["love", "peace"], "text": "إِنَّ اللَّهَ يُحِبُّ الْمُقْسِطِينَ." },
  { "id": "luqman31_20", "ref": "لقمان ٣١:‏٢٠", "themes": ["love", "gratitude"], "text": "وَأَسْبَغَ عَلَيْكُمْ نِعَمَهُ ظَاهِرَةً وَبَاطِنَةً." },
  { "id": "imran3_159", "ref": "آل عمران ٣:‏١٥٩", "themes": ["love", "faith", "wisdom"], "text": "فَإِذَا عَزَمْتَ فَتَوَكَّلْ عَلَى اللَّهِ، إِنَّ اللَّهَ يُحِبُّ الْمُتَوَكِّلِينَ." },
  { "id": "anam6_54", "ref": "الأنعام ٦:‏٥٤", "themes": ["love", "comfort"], "text": "كَتَبَ رَبُّكُمْ عَلَىٰ نَفْسِهِ الرَّحْمَةَ." },
  { "id": "zumar39_62", "ref": "الزمر ٣٩:‏٦٢", "themes": ["prosperity"], "text": "اللَّهُ خَالِقُ كُلِّ شَيْءٍ وَهُوَ عَلَىٰ كُلِّ شَيْءٍ وَكِيلٌ." },
  { "id": "baqara2_245", "ref": "البقرة ٢:‏٢٤٥", "themes": ["prosperity"], "text": "وَاللَّهُ يَقْبِضُ وَيَبْسُطُ وَإِلَيْهِ تُرْجَعُونَ." },
  { "id": "ibrahim14_7", "ref": "إبراهيم ١٤:‏٧", "themes": ["prosperity", "gratitude"], "text": "لَئِن شَكَرْتُمْ لَأَزِيدَنَّكُمْ." },
  { "id": "nisa4_32", "ref": "النساء ٤:‏٣٢", "themes": ["prosperity"], "text": "وَاسْأَلُوا اللَّهَ مِن فَضْلِهِ." },
  { "id": "nahl16_14", "ref": "النحل ١٦:‏١٤", "themes": ["prosperity"], "text": "وَهُوَ الَّذِي سَخَّرَ الْبَحْرَ لِتَأْكُلُوا مِنْهُ لَحْمًا طَرِيًّا." },
  { "id": "imran3_37", "ref": "آل عمران ٣:‏٣٧", "themes": ["prosperity"], "text": "إِنَّ اللَّهَ يَرْزُقُ مَن يَشَاءُ بِغَيْرِ حِسَابٍ." },
  { "id": "kahf18_23", "ref": "الكهف ١٨:‏٢٣", "themes": ["prosperity", "wisdom"], "text": "وَلَا تَقُولَنَّ لِشَيْءٍ إِنِّي فَاعِلٌ ذَٰلِكَ غَدًا إِلَّا أَن يَشَاءَ اللَّهُ." },
  { "id": "nuh71_12", "ref": "نوح ٧١:‏١٢", "themes": ["prosperity"], "text": "وَيُمْدِدْكُم بِأَمْوَالٍ وَبَنِينَ وَيَجْعَل لَّكُمْ جَنَّاتٍ وَيَجْعَل لَّكُمْ أَنْهَارًا." },
  { "id": "talaq65_2", "ref": "الطلاق ٦٥:‏٢", "themes": ["prosperity", "faith"], "text": "وَمَن يَتَّقِ اللَّهَ يَجْعَل لَّهُ مَخْرَجًا وَيَرْزُقْهُ مِنْ حَيْثُ لَا يَحْتَسِبُ." },
  { "id": "inshirah94_5", "ref": "الشرح ٩٤:‏٥", "themes": ["hope"], "text": "فَإِنَّ مَعَ الْعُسْرِ يُسْرًا." },
  { "id": "talaq65_1", "ref": "الطلاق ٦٥:‏١", "themes": ["hope"], "text": "لَعَلَّ اللَّهَ يُحْدِثُ بَعْدَ ذَٰلِكَ أَمْرًا." },
  { "id": "tawbah9_120", "ref": "التوبة ٩:‏١٢٠", "themes": ["hope", "gratitude"], "text": "إِنَّ اللَّهَ لَا يُضِيعُ أَجْرَ الْمُحْسِنِينَ." },
  { "id": "maryam19_64", "ref": "مريم ١٩:‏٦٤", "themes": ["hope", "comfort"], "text": "وَمَا كَانَ رَبُّكَ نَسِيًّا." },
  { "id": "baqara2_216", "ref": "البقرة ٢:‏٢١٦", "themes": ["hope", "wisdom"], "text": "وَعَسَىٰ أَن تَكْرَهُوا شَيْئًا وَهُوَ خَيْرٌ لَّكُمْ، وَعَسَىٰ أَن تُحِبُّوا شَيْئًا وَهُوَ شَرٌّ لَّكُمْ." },
  { "id": "nisa4_146", "ref": "النساء ٤:‏١٤٦", "themes": ["hope"], "text": "فَأُولَٰئِكَ سَوْفَ يُؤْتِيهِمُ اللَّهُ أَجْرًا عَظِيمًا." },
  { "id": "yusuf12_87", "ref": "يوسف ١٢:‏٨٧", "themes": ["hope"], "text": "لَا تَيْأَسُوا مِن رَّوْحِ اللَّهِ، إِنَّهُ لَا يَيْأَسُ مِن رَّوْحِ اللَّهِ إِلَّا الْقَوْمُ الْكَافِرُونَ." },
  { "id": "baqara2_153", "ref": "البقرة ٢:‏١٥٣", "themes": ["hope", "strength"], "text": "إِنَّ اللَّهَ مَعَ الصَّابِرِينَ." },
  { "id": "baqara2_165", "ref": "البقرة ٢:‏١٦٥", "themes": ["love", "faith"], "text": "وَالَّذِينَ آمَنُوا أَشَدُّ حُبًّا لِّلَّهِ." },
  { "id": "hujurat49_10", "ref": "الحجرات ٤٩:‏١٠", "themes": ["faith"], "text": "إِنَّمَا الْمُؤْمِنُونَ إِخْوَةٌ." },
  { "id": "baqara2_62", "ref": "البقرة ٢:‏٦٢", "themes": ["faith"], "text": "مَنْ آمَنَ بِاللَّهِ وَالْيَوْمِ الْآخِرِ وَعَمِلَ صَالِحًا فَلَهُمْ أَجْرُهُمْ عِندَ رَبِّهِمْ." },
  { "id": "baqara2_257", "ref": "البقرة ٢:‏٢٥٧", "themes": ["faith", "strength"], "text": "اللَّهُ وَلِيُّ الَّذِينَ آمَنُوا يُخْرِجُهُم مِّنَ الظُّلُمَاتِ إِلَى النُّورِ." },
  { "id": "imran3_160", "ref": "آل عمران ٣:‏١٦٠", "themes": ["faith", "strength"], "text": "إِن يَنصُرْكُمُ اللَّهُ فَلَا غَالِبَ لَكُمْ." },
  { "id": "muminun23_1", "ref": "المؤمنون ٢٣:‏١", "themes": ["faith"], "text": "قَدْ أَفْلَحَ الْمُؤْمِنُونَ." },
  { "id": "taghabun64_11", "ref": "التغابن ٦٤:‏١١", "themes": ["faith", "comfort"], "text": "وَمَن يُؤْمِن بِاللَّهِ يَهْدِ قَلْبَهُ." },
  { "id": "hadith_faith", "ref": "حديث نبوي", "themes": ["faith"], "text": "الإيمان ما وقر في القلب وصدّقه العمل." },
  { "id": "nisa4_139", "ref": "النساء ٤:‏١٣٩", "themes": ["strength"], "text": "فَإِنَّ الْعِزَّةَ لِلَّهِ جَمِيعًا." },
  { "id": "baqara2_45", "ref": "البقرة ٢:‏٤٥", "themes": ["strength", "hope"], "text": "وَاسْتَعِينُوا بِالصَّبْرِ وَالصَّلَاةِ." },
  { "id": "anfal8_45", "ref": "الأنفال ٨:‏٤٥", "themes": ["strength"], "text": "اثْبُتُوا وَاذْكُرُوا اللَّهَ كَثِيرًا." },
  { "id": "ibrahim14_27", "ref": "إبراهيم ١٤:‏٢٧", "themes": ["strength", "faith"], "text": "يُثَبِّتُ اللَّهُ الَّذِينَ آمَنُوا بِالْقَوْلِ الثَّابِتِ فِي الْحَيَاةِ الدُّنْيَا وَفِي الْآخِرَةِ." },
  { "id": "imran3_139", "ref": "آل عمران ٣:‏١٣٩", "themes": ["strength"], "text": "وَلَا تَهِنُوا وَلَا تَحْزَنُوا وَأَنتُمُ الْأَعْلَوْنَ إِن كُنتُم مُّؤْمِنِينَ." },
  { "id": "baqara2_247", "ref": "البقرة ٢:‏٢٤٧", "themes": ["strength"], "text": "وَاللَّهُ يُؤْتِي مُلْكَهُ مَن يَشَاءُ وَاللَّهُ وَاسِعٌ عَلِيمٌ." },
  { "id": "ghafir40_60", "ref": "غافر ٤٠:‏٦٠", "themes": ["strength", "comfort"], "text": "ادْعُونِي أَسْتَجِبْ لَكُمْ." },
  { "id": "muhammad47_35", "ref": "محمد ٤٧:‏٣٥", "themes": ["strength"], "text": "فَلَا تَهِنُوا وَاللَّهُ مَعَكُمْ." },
  { "id": "fatiha1_2", "ref": "الفاتحة ١:‏٢", "themes": ["gratitude"], "text": "الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ." },
  { "id": "saba34_13", "ref": "سبأ ٣٤:‏١٣", "themes": ["gratitude"], "text": "وَقَلِيلٌ مِّنْ عِبَادِيَ الشَّكُورُ." },
  { "id": "ibrahim14_34", "ref": "إبراهيم ١٤:‏٣٤", "themes": ["gratitude"], "text": "وَإِن تَعُدُّوا نِعْمَتَ اللَّهِ لَا تُحْصُوهَا." },
  { "id": "mulk67_23", "ref": "الملك ٦٧:‏٢٣", "themes": ["gratitude"], "text": "قُلْ هُوَ الَّذِي أَنشَأَكُمْ وَجَعَلَ لَكُمُ السَّمْعَ وَالْأَبْصَارَ وَالْأَفْئِدَةَ." },
  { "id": "baqara2_172", "ref": "البقرة ٢:‏١٧٢", "themes": ["gratitude"], "text": "كُلُوا مِن طَيِّبَاتِ مَا رَزَقْنَاكُمْ وَاشْكُرُوا لِلَّهِ." },
  { "id": "luqman31_14", "ref": "لقمان ٣١:‏١٤", "themes": ["gratitude"], "text": "أَنِ اشْكُرْ لِي وَلِوَالِدَيْكَ." },
  { "id": "imran3_144", "ref": "آل عمران ٣:‏١٤٤", "themes": ["gratitude", "faith"], "text": "وَسَيَجْزِي اللَّهُ الشَّاكِرِينَ." },
  { "id": "hijr15_85", "ref": "الحجر ١٥:‏٨٥", "themes": ["forgiveness"], "text": "فَاصْفَحِ الصَّفْحَ الْجَمِيلَ." },
  { "id": "nur24_22", "ref": "النور ٢٤:‏٢٢", "themes": ["forgiveness"], "text": "وَلْيَعْفُوا وَلْيَصْفَحُوا، أَلَا تُحِبُّونَ أَن يَغْفِرَ اللَّهُ لَكُمْ." },
  { "id": "baqara2_237", "ref": "البقرة ٢:‏٢٣٧", "themes": ["forgiveness"], "text": "وَأَن تَعْفُوا أَقْرَبُ لِلتَّقْوَىٰ." },
  { "id": "nur24_31", "ref": "النور ٢٤:‏٣١", "themes": ["forgiveness"], "text": "وَتُوبُوا إِلَى اللَّهِ جَمِيعًا أَيُّهَ الْمُؤْمِنُونَ لَعَلَّكُمْ تُفْلِحُونَ." },
  { "id": "hud11_90", "ref": "هود ١١:‏٩٠", "themes": ["forgiveness", "comfort"], "text": "إِنَّ رَبِّي رَحِيمٌ وَدُودٌ." },
  { "id": "nisa4_31", "ref": "النساء ٤:‏٣١", "themes": ["forgiveness"], "text": "إِن تَجْتَنِبُوا كَبَائِرَ مَا تُنْهَوْنَ عَنْهُ نُكَفِّرْ عَنكُمْ سَيِّئَاتِكُمْ." },
  { "id": "muminun23_96", "ref": "المؤمنون ٢٣:‏٩٦", "themes": ["forgiveness", "peace"], "text": "ادْفَعْ بِالَّتِي هِيَ أَحْسَنُ السَّيِّئَةَ." },
  { "id": "baqara2_269", "ref": "البقرة ٢:‏٢٦٩", "themes": ["wisdom"], "text": "يُؤْتِي الْحِكْمَةَ مَن يَشَاءُ وَمَن يُؤْتَ الْحِكْمَةَ فَقَدْ أُوتِيَ خَيْرًا كَثِيرًا." },
  { "id": "taha20_114", "ref": "طه ٢٠:‏١١٤", "themes": ["wisdom"], "text": "وَقُل رَّبِّ زِدْنِي عِلْمًا." },
  { "id": "mujadila58_11", "ref": "المجادلة ٥٨:‏١١", "themes": ["wisdom", "faith"], "text": "يَرْفَعِ اللَّهُ الَّذِينَ آمَنُوا مِنكُمْ وَالَّذِينَ أُوتُوا الْعِلْمَ دَرَجَاتٍ." },
  { "id": "alaq96_1", "ref": "العلق ٩٦:‏١", "themes": ["wisdom", "faith"], "text": "اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ." },
  { "id": "baqara2_32", "ref": "البقرة ٢:‏٣٢", "themes": ["wisdom"], "text": "إِنَّكَ أَنتَ الْعَلِيمُ الْحَكِيمُ." },
  { "id": "yusuf12_76", "ref": "يوسف ١٢:‏٧٦", "themes": ["wisdom"], "text": "وَفَوْقَ كُلِّ ذِي عِلْمٍ عَلِيمٌ." },
  { "id": "hashr59_2", "ref": "الحشر ٥٩:‏٢", "themes": ["wisdom"], "text": "فَاعْتَبِرُوا يَا أُولِي الْأَبْصَارِ." },
  { "id": "alaq96_5", "ref": "العلق ٩٦:‏٥", "themes": ["wisdom"], "text": "عَلَّمَ الْإِنسَانَ مَا لَمْ يَعْلَمْ." },
  { "id": "zumar39_9", "ref": "الزمر ٣٩:‏٩", "themes": ["wisdom"], "text": "قُلْ هَلْ يَسْتَوِي الَّذِينَ يَعْلَمُونَ وَالَّذِينَ لَا يَعْلَمُونَ." },
  { "id": "anfal8_46", "ref": "الأنفال ٨:‏٤٦", "themes": ["comfort", "strength"], "text": "وَاصْبِرُوا، إِنَّ اللَّهَ مَعَ الصَّابِرِينَ." },
  { "id": "tawbah9_40", "ref": "التوبة ٩:‏٤٠", "themes": ["comfort", "faith"], "text": "لَا تَحْزَنْ إِنَّ اللَّهَ مَعَنَا." },
  { "id": "nisa4_45", "ref": "النساء ٤:‏٤٥", "themes": ["comfort"], "text": "وَكَفَىٰ بِاللَّهِ وَلِيًّا." },
  { "id": "hadid57_6", "ref": "الحديد ٥٧:‏٦", "themes": ["comfort", "wisdom"], "text": "وَهُوَ عَلِيمٌ بِذَاتِ الصُّدُورِ." },
  { "id": "hud11_115", "ref": "هود ١١:‏١١٥", "themes": ["comfort"], "text": "وَإِنَّ اللَّهَ لَا يُضِيعُ أَجْرَ الْمُحْسِنِينَ." },
  { "id": "shura42_19", "ref": "الشورى ٤٢:‏١٩", "themes": ["comfort", "love"], "text": "اللَّهُ لَطِيفٌ بِعِبَادِهِ." }
]
